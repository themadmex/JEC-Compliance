# Copy this file to .env in the project root and fill in the values.
# Never commit .env to source control.

# ── Azure AD (Entra ID) ───────────────────────────────────────────────────────
# Found in Azure Portal > Azure Active Directory > App registrations > your app
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Session security ──────────────────────────────────────────────────────────
# Any long random string; used to sign cookies
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# ── App URL ───────────────────────────────────────────────────────────────────
# Must match the Redirect URI registered in Azure Portal
# Dev: http://localhost:8000   |   Prod: https://your-domain.com
APP_BASE_URL=http://localhost:8000
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/your-site
